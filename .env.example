# StackPicks — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.

# ── Supabase (Mumbai region, ap-south-1) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub (PAT with public_repo scope only) ──────────────────────────
GITHUB_TOKEN=

# ── Site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cron (random string, used to authenticate scrape endpoint) ────────
CRON_SECRET=

# ── Email (Resend — optional for v1 newsletter) ───────────────────────
RESEND_API_KEY=

# ── Razorpay (DEFERRED — add at the end after KYC) ────────────────────
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_PREMIUM_MONTHLY=
# RAZORPAY_PLAN_SPONSOR_CATEGORY=
# RAZORPAY_PLAN_SPONSOR_FEATURED=

# ── StackPicks Connect — OAuth broker (Nango) ─────────────────────────
# Get these at https://nango.dev (free Hobby tier covers MVP).
# Provider OAuth apps (GitHub, Gmail, Slack, Notion, Discord, Google Drive)
# get registered in Nango — Nango holds the tokens, we just store the
# nango_connection_id per (user, provider).
NANGO_HOST=https://api.nango.dev
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=

# ── StackPicks Connect launch gate ────────────────────────────────────
# Keep false until ~50 providers are wired. When false, non-admins see
# "Coming soon" on /connect; admins (ADMIN_EMAIL) always get the real flow.
# Flip to true to open Connect publicly.
NEXT_PUBLIC_CONNECT_LAUNCHED=false

# ── Resend newsletter (optional — enables auto-sync of signups) ───────
# RESEND_API_KEY already used for transactional email. Add an Audience ID
# from resend.com → Audiences to auto-add web signups to your sending list.
RESEND_AUDIENCE_ID=

# ── Connect API-key encryption (AES-256-GCM for stored API keys) ──────
# Any random 32+ char string. Used to encrypt user API keys (Firecrawl etc.)
# stored in api_key_connections. Set in Railway. Generate: openssl rand -hex 32
CONNECT_ENC_KEY=

# ── StackPicks AutoDM (multi-tenant IG auto-DM product) ───────────────
# Shared Meta-webhook verify token (one per Meta App, not per tenant).
# Set anything random — paste the SAME value into Meta App Dashboard → Webhooks.
AUTODM_META_VERIFY_TOKEN=
# App Secret from the Meta App Dashboard (different from MCP / publisher app).
# Used to verify x-hub-signature-256 on every inbound webhook.
AUTODM_META_APP_SECRET=
# Tenant-token encryption key (separate from CONNECT_ENC_KEY).
# Generate: openssl rand -base64 32   (must decode to exactly 32 bytes)
AUTODM_ENC_KEY=
